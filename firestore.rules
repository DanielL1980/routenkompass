rules_version = '2';

// Firestore-Regeln fuer RoutenKompass
// Jeder Nutzer darf ausschliesslich auf seine eigenen Routen zugreifen
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/routen/{routeId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
