# Firebase Web-App-Konfiguration (Firebase Console -> Projekteinstellungen)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenRouteService API-Key (kostenlos: openrouteservice.org)
VITE_ORS_API_KEY=

# HINWEIS: Der Anthropic API-Key gehoert NICHT hier rein.
# Der Claude-Aufruf laeuft ueber eine Firebase Cloud Function (functions/index.js),
# damit der Key niemals im Client-Bundle landet.
# Setzen via: firebase functions:secrets:set ANTHROPIC_API_KEY
